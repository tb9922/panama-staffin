# Generate JWT_SECRET with: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=replace_with_64_char_hex_string

# Optional - only needed for first deployment to seed initial users.
# Once users are created via the UI, these can be removed.
# Generate hashes with: node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
# ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
# VIEWER_PASSWORD_HASH=replace_with_bcrypt_hash

ALLOWED_ORIGIN=http://localhost:5173
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Authentication
JWT_EXPIRES_IN=4h
# SESSION_SECRET defaults to JWT_SECRET if unset.
# SESSION_SECRET=replace_with_random_hex

# Database - PostgreSQL
# Start with: docker compose up -d
DB_HOST=localhost
DB_PORT=5432
DB_NAME=panama_dev
DB_USER=panama
DB_PASSWORD=CHANGE_ME

# Connection budget: PM2 workers * DB_POOL_MAX <= postgres max_connections - reserve
# Example: 4 workers * 20 pool max = 80 client connections, leaving headroom on default PG 100.
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECT_TIMEOUT=5000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=60000

# DB_SSL defaults to ON. Set to 'false' only for local development without SSL.
DB_SSL=false

# Bcrypt hashing cost (default 12). Lower for test speed (for example 4).
# BCRYPT_ROUNDS=12

# Sentry monitoring (optional)
# SENTRY_DSN=https://xxx@sentry.io/yyy
SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Frontend Sentry DSN (optional)
# VITE_SENTRY_DSN=https://xxx@sentry.io/yyy

# Metrics endpoint (optional). If unset, GET /metrics returns 404.
# METRICS_TOKEN=replace_with_long_random_bearer_token

# Webhook secret encryption key (64 hex chars = 32 bytes). Required if using webhooks.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# Offsite backup / restore verification (optional but recommended in production)
# BACKUP_S3_BUCKET=your-bucket-name
# BACKUP_SCP_TARGET=user@host:/srv/backups/panama
# VERIFY_AFTER_BACKUP=true
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# Regulated document upload scanning (optional but recommended in production)
# Example for ClamAV: UPLOAD_SCAN_COMMAND=clamscan
# UPLOAD_SCAN_ARGS=--no-summary
# UPLOAD_SCAN_TIMEOUT_MS=30000
