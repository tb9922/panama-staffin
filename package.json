{
  "name": "panama-staffing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"nodemon server.js\" \"vite\"",
    "server": "node server.js",
    "client": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "stats": "node scripts/stats.js",
    "preview": "vite preview",
    "audit:routes": "node scripts/audit-routes.js",
    "verify:action-backfill": "node scripts/verify-action-backfill.js",
    "verify:v1-operational": "node scripts/verify-v1-operational-gates.js",
    "invite:staff": "node scripts/invite-staff.js",
    "test": "npm run test:ci",
    "test:ci": "vitest run tests/unit src/contexts src/lib src/hooks",
    "test:watch": "vitest",
    "test:integration": "node scripts/run-bash-script.mjs scripts/test-integration.sh",
    "test:frontend": "vitest run --config vitest.config.frontend.js",
    "test:frontend:watch": "vitest --config vitest.config.frontend.js",
    "test:e2e": "node scripts/run-bash-script.mjs scripts/test-e2e.sh",
    "test:golden": "playwright test tests/e2e/golden-journey.spec.js tests/e2e/role-matrix.spec.js --project=chromium",
    "test:release": "npm run lint && npm run build && npm run test:frontend && npm run test:e2e"
  },
  "dependencies": {
    "@sentry/node": "^10.40.0",
    "@sentry/react": "^10.40.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^21.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "multer": "^2.0.2",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0",
    "dompurify": "^3.4.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10",
    "exceljs": {
      "uuid": "^14.0.0"
    },
    "nodemon": {
      "brace-expansion": "^5.0.5"
    },
    "@fastify/otel": {
      "brace-expansion": "^5.0.5"
    },
    "glob": {
      "brace-expansion": "^1.1.13"
    },
    "readdir-glob": {
      "brace-expansion": "^2.0.3"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
